---
interface Props {
  icp?: string;
}

const { icp = '' } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="px-6 py-4 border-t border-border bg-card">
  <div class="max-w-3xl mx-auto">
    <!-- 主行：版权 + 链接 -->
    <div class="flex items-center justify-between flex-wrap gap-2">
      <p class="m-0 text-[0.8125rem] text-muted">&copy; {year} DevTools. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="/about" class="text-[0.8125rem] text-muted hover:text-accent transition-[color] duration-150">关于</a>
        <a
          href="https://gitee.com/baixuanz"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[0.8125rem] text-muted hover:text-accent transition-[color] duration-150"
        >Gitee</a>
        <a
          href="https://github.com/BaixuanZhu/DevTools"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[0.8125rem] text-muted hover:text-accent transition-[color] duration-150"
        >GitHub</a>
        <a
          href="/feedback"
          class="text-[0.8125rem] text-muted hover:text-accent transition-[color] duration-150"
        >反馈</a>
      </div>
    </div>

    <!-- ICP 行（如存在）-->
    {icp && (
      <div class="mt-1">
        <p class="m-0">
          <a
            href="https://beian.miit.gov.cn/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[0.8125rem] text-muted hover:text-accent transition-[color] duration-150"
          >
            {icp}
          </a>
        </p>
      </div>
    )}
  </div>
</footer>
