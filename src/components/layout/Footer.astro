---
interface Props {
  icp?: string;
}

const { icp = '' } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="px-6 py-4 border-t border-border bg-card">
  <div class="flex justify-center items-center gap-4 flex-wrap">
    <p class="m-0 text-[0.8125rem] text-muted">&copy; {year} DevTools. All rights reserved.</p>
    {icp && (
      <p class="m-0">
        <a
          href="https://beian.miit.gov.cn/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[0.8125rem] text-muted hover:text-accent"
        >
          {icp}
        </a>
      </p>
    )}
  </div>
</footer>
