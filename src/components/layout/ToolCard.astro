---
import type { ToolMeta } from '../../data/tools';

interface Props {
  tool: ToolMeta;
}

const { tool } = Astro.props;
---

<a href={tool.path} class="flex items-start gap-6 p-6 bg-card border border-border rounded-lg transition-[border-color,box-shadow] duration-150 hover:border-accent hover:shadow-[0_2px_8px_rgba(0,0,0,0.06)]">
  <span class="text-[1.75rem] leading-none shrink-0">{tool.icon}</span>
  <div class="flex-1 min-w-0">
    <h3 class="m-0 mb-1 text-[0.9375rem] font-semibold">{tool.name}</h3>
    <p class="m-0 text-[0.8125rem] text-muted leading-normal">{tool.description}</p>
  </div>
</a>
