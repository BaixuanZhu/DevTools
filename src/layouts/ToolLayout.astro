---
import Layout from './Layout.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import RelatedTools from '../components/layout/RelatedTools.astro';
import { getToolsByCategory, getCategories, getToolBySlug, getToolById, slugCategoryMap } from '../data/tools';
import { getToolFaqs } from '../data/tool-faqs';

interface Props {
  /** 页面标题 */
  title?: string;
  /** 页面描述（优先使用传入值，否则从 seoDescription 回退） */
  description?: string;
  /** 工具 ID（格式：categorySlug/toolSlug，如 encoding/base64） */
  toolId?: string;
}

const { title, description, toolId = '' } = Astro.props;
const currentPath = toolId ? `/${toolId}` : Astro.url.pathname;
const categories = getCategories();
const toolsByCategory = getToolsByCategory();

/** 通过 toolId 查找工具元数据 */
const toolMeta = toolId ? getToolBySlug(toolId) : undefined;

/** 确定 title：props.title > toolMeta.title > 自动拼接 "{name} - DevTools" */
const finalTitle = title || toolMeta?.title || (toolMeta ? `${toolMeta.name} - DevTools` : undefined);

/** 确定最终 description：优先 props → seoDescription → 默认值 */
const finalDescription = description || toolMeta?.seoDescription || undefined;

/** 提取 keywords */
const keywords = toolMeta?.keywords;

/** 获取相关工具 ID 列表 */
const relatedToolIds = toolMeta?.relatedToolIds || [];

/** 获取当前工具的 FAQ 列表 */
const faqs = getToolFaqs(toolId);

/** 站点基础 URL */
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://tools.openbong.cloud';

/** 构建 JSON-LD 结构化数据 */
const jsonLdItems: object[] = [];

if (toolId && toolMeta) {
  const [categorySlug] = toolId.split('/');
  const categoryName = slugCategoryMap[categorySlug] || categorySlug;
  const toolPageUrl = `${siteUrl}/${toolId}`;

  // 1. BreadcrumbList — 面包屑结构化数据
  jsonLdItems.push({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: '首页',
        item: siteUrl,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: categoryName,
        item: `${siteUrl}/${categorySlug}`,
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: toolMeta.name,
      },
    ],
  });

  // 2. WebPage — 页面信息
  jsonLdItems.push({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: toolMeta.name,
    description: toolMeta.seoDescription,
    url: toolPageUrl,
    breadcrumb: {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '首页', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: categoryName },
        { '@type': 'ListItem', position: 3, name: toolMeta.name },
      ],
    },
  });

  // 3. SoftwareApplication — 工具信息
  jsonLdItems.push({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: toolMeta.name,
    description: toolMeta.seoDescription,
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Browser',
    offers: {
      '@type': 'Offer',
      price: '0',
    },
  });
}

/** 构建面包屑导航项 */
const breadcrumbItems = toolId && toolMeta
  ? (() => {
      const [categorySlug] = toolId.split('/');
      const categoryName = slugCategoryMap[categorySlug] || categorySlug;
      return [
        { label: '首页', href: '/' },
        { label: categoryName },
        { label: toolMeta.name },
      ];
    })()
  : [];
---

<Layout title={finalTitle} description={finalDescription} jsonLd={jsonLdItems} keywords={keywords}>
  <div id="app">
    <!-- Sidebar (fixed, full height) -->
    <aside
      x-data="{ isOpen: false }"
      @sidebar-toggle.window="isOpen = !isOpen"
      @sidebar-close.window="isOpen = false"
      @keydown.escape="isOpen = false"
      :class="isOpen && 'sidebar-open'"
      class="sidebar fixed left-0 top-0 bottom-0 w-[240px] border-r border-border bg-card flex flex-col"
      role="navigation"
      aria-label="工具导航"
    >
      <!-- Logo 区域 (sticky 顶部) -->
      <div class="sticky top-0 z-10 bg-card border-b border-border h-[57px] flex items-center justify-between px-6 shrink-0">
        <a
          href="/"
          class="group flex items-center gap-1.5 text-lg font-semibold text-text hover:text-accent transition-[color] duration-150"
          aria-label="DevTools 首页"
        >
          <svg
            class="w-6 h-6 text-text group-hover:text-accent group-hover:-rotate-12 transition-[transform,color] duration-300 ease-out"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
          </svg>
          <span>DevTools</span>
        </a>
        <!-- 移动端关闭按钮 -->
        <button
          class="lg:hidden flex items-center justify-center w-8 h-8 rounded-sm text-muted hover:text-accent hover:bg-hover transition-[color,background-color] duration-150 cursor-pointer border-none bg-transparent focus:outline-none"
          aria-label="关闭导航菜单"
          @click="$dispatch('sidebar-close')"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

      <!-- 导航内容 (可滚动) -->
      <div class="flex-1 sidebar-nav-scroll overflow-y-auto py-2">
        <!-- 分类导航 -->
        {categories.map((category) => (
          <div>
            <h3 class="text-xs font-semibold text-muted px-4 py-4 pb-1 uppercase tracking-wider">{category}</h3>
            <ul class="list-none m-0 p-0">
              {toolsByCategory[category].map((tool) => (
                <li>
                  <a
                    href={tool.path}
                    class:list={[
                      'flex items-center gap-2 px-4 py-2 text-sm text-text transition-[background-color] duration-150 hover:bg-hover focus:outline-none',
                      currentPath === tool.path && 'bg-hover text-accent font-medium',
                    ]}
                  >
                    <span class="text-base w-6 text-center shrink-0">{tool.icon}</span>
                    <span>{tool.name}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </aside>

    <!-- Mobile overlay -->
    <div
      x-data
      x-show="$el.closest('#app')?.querySelector('aside')?.classList.contains('sidebar-open')"
      @click="$dispatch('sidebar-close')"
      class="sidebar-overlay fixed inset-0 bg-black/30 z-[99] hidden"
      x-cloak
    ></div>

    <!-- 右侧区域 -->
    <div class="ml-[240px] max-lg:ml-0 flex flex-col min-h-0 min-h-dvh">
      <!-- Header -->
      <header class="sticky top-0 z-50 flex items-center justify-between px-6 py-2 border-b border-border bg-card h-[57px] shrink-0">
        <!-- 左侧：汉堡按钮 + 移动端 Logo -->
        <div class="flex items-center gap-4">
          <button
            class="hidden max-lg:flex flex-col gap-1 p-2 border-none bg-transparent cursor-pointer focus:outline-none"
            aria-label="打开导航菜单"
            x-data="{ expanded: false }"
            :aria-expanded="expanded"
            @click="$dispatch('sidebar-toggle'); expanded = !expanded"
            @sidebar-toggle.window="expanded = !$el.getAttribute('aria-expanded')"
            @sidebar-close.window="expanded = false"
          >
            <span class="block w-[18px] h-[2px] bg-text rounded-[1px]" aria-hidden="true"></span>
            <span class="block w-[18px] h-[2px] bg-text rounded-[1px]" aria-hidden="true"></span>
            <span class="block w-[18px] h-[2px] bg-text rounded-[1px]" aria-hidden="true"></span>
          </button>
          <!-- 移动端 Logo -->
          <a href="/" class="lg:hidden group flex items-center gap-1.5 text-lg font-semibold text-text hover:text-accent transition-[color] duration-150" aria-label="DevTools 首页">
            <svg class="w-6 h-6 text-text group-hover:text-accent group-hover:-rotate-12 transition-[transform,color] duration-300 ease-out" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
            <span>DevTools</span>
          </a>
        </div>

        <!-- 右侧：工具按钮区 -->
        <div class="flex items-center gap-1" x-data="{ showPanel: false }">

          <!-- 收藏夹按钮 + 下拉面板 -->
          <div class="relative">
            <button
              class="flex items-center justify-center w-9 h-9 rounded-sm text-muted hover:text-accent hover:bg-hover transition-[color,background-color] duration-150 cursor-pointer border-none bg-transparent focus:outline-none"
              aria-label="收藏的工具"
              @click="showPanel = !showPanel"
              :aria-expanded="showPanel.toString()"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
            </button>

            <!-- 收藏夹下拉面板 -->
            <div
              x-show="showPanel"
              @click.outside="showPanel = false"
              @keydown.escape="showPanel = false"
              x-transition:enter="transition ease-out duration-150"
              x-transition:enter-start="opacity-0 -translate-y-1"
              x-transition:enter-end="opacity-100 translate-y-0"
              x-transition:leave="transition ease-in duration-100"
              x-transition:leave-start="opacity-100 translate-y-0"
              x-transition:leave-end="opacity-0 -translate-y-1"
              class="absolute right-0 top-full mt-2 w-[260px] bg-card border border-border rounded-lg shadow-lg py-2 z-50"
              x-cloak
              role="menu"
            >
              <!-- 标题区 -->
              <div class="flex items-center justify-between px-4 pb-2 mb-1 border-b border-border">
                <span class="text-xs font-semibold text-muted uppercase tracking-wider">收藏的工具</span>
                <span
                  x-show="$store.favorites.list.length > 0"
                  class="text-xs text-muted bg-hover px-1.5 py-0.5 rounded-sm"
                  x-text="$store.favorites.list.length"
                ></span>
              </div>

              <!-- 工具列表 -->
              <template x-for="tool in $store.favorites.list" :key="tool.path">
                <a
                  :href="tool.path"
                  class="flex items-center gap-2 px-4 py-2 text-sm text-text hover:bg-hover transition-[background-color] duration-150"
                  @click="showPanel = false"
                >
                  <span class="text-base w-6 text-center shrink-0" x-text="tool.icon"></span>
                  <span x-text="tool.name"></span>
                </a>
              </template>

              <!-- 空状态 -->
              <div x-show="$store.favorites.list.length === 0" class="px-4 py-6 text-center">
                <p class="text-sm text-muted mb-1">还没有收藏的工具</p>
                <p class="text-xs text-muted">在首页卡片上点击 ⭐ 收藏常用工具</p>
              </div>

              <!-- 底部操作 -->
              <div x-show="$store.favorites.list.length > 0" class="border-t border-border mt-1 pt-1 px-4">
                <button
                  class="text-xs text-muted hover:text-accent transition-[color] duration-150 cursor-pointer bg-transparent border-none py-1"
                  @click.prevent="$store.favorites.clearAll(); showPanel = false"
                >
                  清空全部
                </button>
              </div>
            </div>
          </div>

          <!-- 暗色模式按钮（仅 UI 预留） -->
          <button
            class="flex items-center justify-center w-9 h-9 rounded-sm text-muted hover:text-accent hover:bg-hover transition-[color,background-color] duration-150 cursor-pointer border-none bg-transparent focus:outline-none"
            aria-label="切换暗色模式（即将支持）"
            @click="$store.toast.success('暗色模式即将支持，敬请期待')"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
          </button>

          <!-- GitHub 链接 -->
          <a
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center w-9 h-9 rounded-sm text-muted hover:text-accent hover:bg-hover transition-[color,background-color] duration-150 focus:outline-none"
            aria-label="GitHub 仓库"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
            </svg>
          </a>
        </div>
      </header>

      <!-- Main content -->
      <main class="flex-1 p-8 overflow-y-auto overflow-x-hidden max-w-full max-md:p-4">
        {breadcrumbItems.length > 0 && <Breadcrumb items={breadcrumbItems} />}
        <slot />
        {faqs.length > 0 && (
          <section class="mt-12 pt-8 border-t border-border">
            <h2 class="text-lg font-semibold text-text mb-4">常见问题</h2>
            <div class="space-y-0 divide-y divide-border">
              {faqs.map((faq) => (
                <details class="group py-4">
                  <summary class="flex items-center justify-between cursor-pointer text-[0.8125rem] text-text hover:text-accent transition-[color] duration-150 list-none">
                    <span class="[&_code]:bg-hover [&_code]:text-text [&_code]:font-mono [&_code]:text-xs [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded-sm [&_strong]:text-text [&_strong]:font-semibold" set:html={faq.question} />
                    <svg class="h-4 w-4 shrink-0 text-muted transition-transform duration-150 group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" />
                    </svg>
                  </summary>
                  <div class="pt-2 text-[0.8125rem] text-muted leading-relaxed [&_code]:bg-hover [&_code]:text-text [&_code]:font-mono [&_code]:text-xs [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded-sm [&_strong]:text-text [&_strong]:font-semibold" set:html={faq.answer} />
                </details>
              ))}
            </div>
          </section>
        )}
        {relatedToolIds.length > 0 && (
          <section class="mt-12 pt-8 border-t border-border">
            <h2 class="text-lg font-semibold text-text mb-4">相关工具</h2>
            <RelatedTools toolIds={relatedToolIds} />
          </section>
        )}
      </main>

      <!-- Footer -->
      <Footer />
    </div>

    <!-- Alpine Toast -->
    <div
      class="fixed top-4 left-1/2 -translate-x-1/2 z-[100] flex flex-col gap-2"
      x-cloak
      x-data
      set:html={`<template x-for="toast in $store.toast.items" :key="toast.id">
        <div
          :class="{
            'bg-card border-border text-success': toast.type === 'success',
            'bg-red-50 border-error text-error': toast.type === 'error',
          }"
          class="px-4 py-2 rounded-md border shadow-sm text-sm font-sans"
          x-text="toast.message"
          x-transition
        ></div>
      </template>`}
    ></div>
  </div>

  <style>
    /* 移动端侧边栏行为 */
    @media (max-width: 1023px) {
      .sidebar {
        left: 0;
        top: 0;
        z-index: 100;
        transform: translateX(-100%);
        transition: transform 250ms ease;
        height: 100vh;
      }
      .sidebar.sidebar-open {
        transform: translateX(0);
      }
      .sidebar-overlay {
        display: block;
      }
    }
  </style>
</Layout>
