---
import Layout from './Layout.astro';
import Footer from '../components/layout/Footer.astro';
import { getToolsByCategory, getCategories, tools, type ToolMeta } from '../data/tools';

interface Props {
  title?: string;
  description?: string;
  toolId?: string;
}

const { title, description, toolId = '' } = Astro.props;
const currentPath = toolId ? `/${toolId}` : Astro.url.pathname;
const categories = getCategories();
const toolsByCategory = getToolsByCategory();

// 序列化工具数据供客户端搜索使用
const toolsJson = JSON.stringify(
  tools.map((t: ToolMeta) => ({
    id: t.id,
    name: t.name,
    description: t.description,
  })),
);
---

<Layout title={title} description={description}>
  <div id="app" class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="flex items-center justify-between px-6 py-2 border-b border-border bg-card h-[57px] shrink-0">
      <div class="flex items-center gap-4">
        <button
          class="hidden max-lg:flex flex-col gap-1 p-2 border-none bg-transparent cursor-pointer"
          aria-label="打开导航菜单"
          x-data="{ expanded: false }"
          :aria-expanded="expanded"
          @click="$dispatch('sidebar-toggle'); expanded = !expanded"
          @sidebar-toggle.window="expanded = !$el.getAttribute('aria-expanded')"
          @sidebar-close.window="expanded = false"
        >
          <span class="block w-[18px] h-[2px] bg-text rounded-[1px]" aria-hidden="true"></span>
          <span class="block w-[18px] h-[2px] bg-text rounded-[1px]" aria-hidden="true"></span>
          <span class="block w-[18px] h-[2px] bg-text rounded-[1px]" aria-hidden="true"></span>
        </button>
        <a href="/" class="text-lg font-semibold text-text hover:text-accent transition-colors duration-150">DevTools</a>
      </div>

      <!-- SearchBar (Alpine) -->
      <div
        class="w-[280px] max-lg:hidden"
        x-data="{
          query: '',
          tools: [],
          init() {
            this.tools = JSON.parse(decodeURIComponent('${encodeURIComponent(toolsJson)}'));
          },
          get filtered() {
            if (!this.query.trim()) return null;
            const q = this.query.toLowerCase();
            return this.tools.filter(t => t.name.toLowerCase().includes(q) || t.description.toLowerCase().includes(q));
          }
        }"
      >
        <div class="flex items-center gap-2 px-4 py-2 border border-border rounded-md bg-card transition-colors duration-150 focus-within:border-accent">
          <span class="text-sm shrink-0">🔍</span>
          <input
            type="text"
            x-model="query"
            placeholder="搜索工具..."
            class="flex-1 border-none outline-none text-sm font-sans text-text bg-transparent placeholder:text-muted"
            @input.debounce.150ms="$dispatch('search-results', { tools: filtered || [], query: query })"
          />
          <button
            x-show="query"
            x-cloak
            @click="query = ''; $dispatch('search-results', { tools: [], query: '' })"
            class="border-none bg-transparent cursor-pointer text-muted text-xs px-1 py-0.5 rounded-sm hover:text-text"
            aria-label="清除搜索"
          >✕</button>
        </div>
      </div>
    </header>

    <!-- Main area -->
    <div class="flex flex-1 overflow-hidden">
      <!-- Sidebar (Alpine) -->
      <aside
        x-data="{ isOpen: false }"
        @sidebar-toggle.window="isOpen = !isOpen"
        @sidebar-close.window="isOpen = false"
        @keydown.escape="isOpen = false"
        :class="isOpen && 'sidebar-open'"
        class="sidebar w-[240px] h-[calc(100vh-57px-49px)] overflow-y-auto border-r border-border bg-card py-2 shrink-0"
        role="navigation"
        aria-label="工具导航"
      >
        <!-- 首页 -->
        <div class="py-1">
          <a
            href="/"
            class:list={['flex items-center gap-2 px-4 py-2 text-sm text-text transition-colors duration-150 hover:bg-hover', currentPath === '/' && 'bg-hover text-accent font-medium border-r-2 border-accent']}
          >
            <span class="text-base w-6 text-center shrink-0">🏠</span>
            <span>首页</span>
          </a>
        </div>
        <div class="h-px bg-border mx-4 my-1"></div>

        <!-- 分类导航 -->
        {categories.map((category) => (
          <div>
            <h3 class="text-xs font-semibold text-muted px-4 py-4 pb-1 uppercase tracking-wider">{category}</h3>
            <ul class="list-none m-0 p-0">
              {toolsByCategory[category].map((tool) => (
                <li>
                  <a
                    href={tool.path}
                    class:list={[
                      'flex items-center gap-2 px-4 py-2 text-sm text-text transition-colors duration-150 hover:bg-hover',
                      currentPath === tool.path && 'bg-hover text-accent font-medium border-r-2 border-accent',
                    ]}
                  >
                    <span class="text-base w-6 text-center shrink-0">{tool.icon}</span>
                    <span>{tool.name}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </aside>

      <!-- Mobile overlay -->
      <div
        x-data
        x-show="$el.closest('#app')?.querySelector('aside')?.classList.contains('sidebar-open')"
        @click="$dispatch('sidebar-close')"
        class="sidebar-overlay fixed inset-0 bg-black/30 z-[99] hidden"
        x-cloak
      ></div>

      <!-- Content -->
      <main class="flex-1 p-8 overflow-y-auto max-w-full max-md:p-4">
        <slot />
      </main>
    </div>

    <Footer />
  </div>

  <!-- Alpine Toast -->
  <div
    class="fixed top-4 left-1/2 -translate-x-1/2 z-[100] flex flex-col gap-2"
    x-cloak
    x-data
  >
    <template x-for="toast in $store.toast.items" :key="toast.id">
      <div
        :class="{
          'bg-card border-border text-success': toast.type === 'success',
          'bg-red-50 border-error text-error': toast.type === 'error',
        }"
        class="px-4 py-2 rounded-md border shadow-sm text-sm font-sans"
        x-text="toast.message"
        x-transition
      ></div>
    </template>
  </div>
</Layout>

<style>
  /* 移动端侧边栏行为 — Alpine 与 Tailwind 响应式配合 */
  @media (max-width: 1023px) {
    .sidebar {
      position: fixed;
      left: 0;
      top: 57px;
      z-index: 100;
      transform: translateX(-100%);
      transition: transform 250ms ease;
      height: calc(100vh - 57px);
    }
    .sidebar.sidebar-open {
      transform: translateX(0);
    }
    .sidebar-overlay {
      display: block;
    }
  }
</style>
