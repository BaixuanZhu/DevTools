---
import Layout from './Layout.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import { getToolsByCategory, getCategories, getToolBySlug, slugCategoryMap, categorySlugMap, type ToolCategory } from '../data/tools';

interface Props {
  /** 页面标题 */
  title?: string;
  /** 页面描述（优先使用传入值，否则从 seoDescription 回退） */
  description?: string;
  /** 工具 ID（格式：categorySlug/toolSlug，如 encoding/base64） */
  toolId?: string;
}

const { title, description, toolId = '' } = Astro.props;
const currentPath = toolId ? `/${toolId}` : Astro.url.pathname;
const categories = getCategories();
const toolsByCategory = getToolsByCategory();

/** 通过 toolId 查找工具元数据 */
const toolMeta = toolId ? getToolBySlug(toolId) : undefined;

/** 确定最终 description：优先 props → seoDescription → 默认值 */
const finalDescription = description || toolMeta?.seoDescription || undefined;

/** 站点基础 URL */
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://tools.openbong.cloud';

/** 构建 JSON-LD 结构化数据 */
const jsonLdItems: object[] = [];

if (toolId && toolMeta) {
  const [categorySlug] = toolId.split('/');
  const categoryName = slugCategoryMap[categorySlug] || categorySlug;
  const toolPageUrl = `${siteUrl}/${toolId}`;

  // 1. BreadcrumbList — 面包屑结构化数据
  jsonLdItems.push({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: '首页',
        item: siteUrl,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: categoryName,
        item: `${siteUrl}/${categorySlug}`,
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: toolMeta.name,
      },
    ],
  });

  // 2. WebPage — 页面信息
  jsonLdItems.push({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: toolMeta.name,
    description: toolMeta.seoDescription,
    url: toolPageUrl,
    breadcrumb: {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '首页', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: categoryName },
        { '@type': 'ListItem', position: 3, name: toolMeta.name },
      ],
    },
  });

  // 3. SoftwareApplication — 工具信息
  jsonLdItems.push({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: toolMeta.name,
    description: toolMeta.seoDescription,
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Browser',
    offers: {
      '@type': 'Offer',
      price: '0',
    },
  });
}

/** 构建面包屑导航项 */
const breadcrumbItems = toolId && toolMeta
  ? (() => {
      const [categorySlug] = toolId.split('/');
      const categoryName = slugCategoryMap[categorySlug] || categorySlug;
      return [
        { label: '首页', href: '/' },
        { label: categoryName },
        { label: toolMeta.name },
      ];
    })()
  : [];
---

<Layout title={title} description={finalDescription} jsonLd={jsonLdItems}>
  <div id="app" class="h-screen grid grid-rows-[auto_minmax(0,1fr)_auto]">
    <!-- Header (simplified - no search bar) -->
    <header class="sticky top-0 z-50 flex items-center justify-between px-6 py-2 border-b border-border bg-card h-[57px] shrink-0">
      <div class="flex items-center gap-4">
        <button
          class="hidden max-lg:flex flex-col gap-1 p-2 border-none bg-transparent cursor-pointer"
          aria-label="打开导航菜单"
          x-data="{ expanded: false }"
          :aria-expanded="expanded"
          @click="$dispatch('sidebar-toggle'); expanded = !expanded"
          @sidebar-toggle.window="expanded = !$el.getAttribute('aria-expanded')"
          @sidebar-close.window="expanded = false"
        >
          <span class="block w-[18px] h-[2px] bg-text rounded-[1px]" aria-hidden="true"></span>
          <span class="block w-[18px] h-[2px] bg-text rounded-[1px]" aria-hidden="true"></span>
          <span class="block w-[18px] h-[2px] bg-text rounded-[1px]" aria-hidden="true"></span>
        </button>
        <a href="/" class="text-lg font-semibold text-text hover:text-accent transition-colors duration-150">DevTools</a>
      </div>
    </header>

    <!-- Main area -->
    <div class="flex overflow-hidden min-h-0">
      <!-- Sidebar (Alpine) -->
      <aside
        x-data="{ isOpen: false }"
        @sidebar-toggle.window="isOpen = !isOpen"
        @sidebar-close.window="isOpen = false"
        @keydown.escape="isOpen = false"
        :class="isOpen && 'sidebar-open'"
        class="sidebar w-[240px] overflow-y-auto border-r border-border bg-card py-2 shrink-0"
        role="navigation"
        aria-label="工具导航"
      >
        <!-- 首页 -->
        <div class="py-1">
          <a
            href="/"
            class:list={['flex items-center gap-2 px-4 py-2 text-sm text-text transition-colors duration-150 hover:bg-hover', currentPath === '/' && 'bg-hover text-accent font-medium border-r-2 border-accent']}
          >
            <span class="text-base w-6 text-center shrink-0">🏠</span>
            <span>首页</span>
          </a>
        </div>
        <div class="h-px bg-border mx-4 my-1"></div>

        <!-- 分类导航 -->
        {categories.map((category) => (
          <div>
            <h3 class="text-xs font-semibold text-muted px-4 py-4 pb-1 uppercase tracking-wider">{category}</h3>
            <ul class="list-none m-0 p-0">
              {toolsByCategory[category].map((tool) => (
                <li>
                  <a
                    href={tool.path}
                    class:list={[
                      'flex items-center gap-2 px-4 py-2 text-sm text-text transition-colors duration-150 hover:bg-hover',
                      currentPath === tool.path && 'bg-hover text-accent font-medium border-r-2 border-accent',
                    ]}
                  >
                    <span class="text-base w-6 text-center shrink-0">{tool.icon}</span>
                    <span>{tool.name}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </aside>

      <!-- Mobile overlay -->
      <div
        x-data
        x-show="$el.closest('#app')?.querySelector('aside')?.classList.contains('sidebar-open')"
        @click="$dispatch('sidebar-close')"
        class="sidebar-overlay fixed inset-0 bg-black/30 z-[99] hidden"
        x-cloak
      ></div>

      <!-- Content -->
      <main class="flex-1 p-8 overflow-y-auto overflow-x-hidden max-w-full max-md:p-4">
        {breadcrumbItems.length > 0 && <Breadcrumb items={breadcrumbItems} />}
        <slot />
      </main>
    </div>

    <Footer />
  </div>

  <!-- Alpine Toast -->
  <div
    class="fixed top-4 left-1/2 -translate-x-1/2 z-[100] flex flex-col gap-2"
    x-cloak
    x-data
  >
    <template x-for="toast in $store.toast.items" :key="toast.id">
      <div
        :class="{
          'bg-card border-border text-success': toast.type === 'success',
          'bg-red-50 border-error text-error': toast.type === 'error',
        }"
        class="px-4 py-2 rounded-md border shadow-sm text-sm font-sans"
        x-text="toast.message"
        x-transition
      ></div>
    </template>
  </div>
</Layout>

<style>
  /* 移动端侧边栏行为 — Alpine 与 Tailwind 响应式配合 */
  @media (max-width: 1023px) {
    .sidebar {
      position: fixed;
      left: 0;
      top: 57px;
      z-index: 100;
      transform: translateX(-100%);
      transition: transform 250ms ease;
      height: calc(100vh - 57px);
    }
    .sidebar.sidebar-open {
      transform: translateX(0);
    }
    .sidebar-overlay {
      display: block;
    }
  }
</style>
