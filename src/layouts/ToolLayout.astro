---
import Layout from './Layout.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import RelatedTools from '../components/layout/RelatedTools.astro';
import Toast from '../components/layout/Toast.astro';
import { Star, Sun, Wrench, ChevronDown } from '@lucide/astro';
import { siGithub, siGitee } from 'simple-icons';
import { getToolsByCategory, getCategories, getToolBySlug, getToolById, slugCategoryMap } from '../data/tools';
import { getToolFaqs } from '../data/tool-faqs';

interface Props {
  /** 页面标题 */
  title?: string;
  /** 页面描述（优先使用传入值，否则从 seoDescription 回退） */
  description?: string;
  /** 工具 ID（格式：categorySlug/toolSlug，如 encoding/base64） */
  toolId?: string;
  /** 额外的 JSON-LD 结构化数据（透传至 Layout，如首页的 ItemList） */
  jsonLd?: object | object[];
}

const { title, description, toolId = '', jsonLd } = Astro.props;
const currentPath = toolId ? `/${toolId}` : Astro.url.pathname;
const categories = getCategories();
const toolsByCategory = getToolsByCategory();

/** 通过 toolId 查找工具元数据 */
const toolMeta = toolId ? getToolBySlug(toolId) : undefined;

/** 确定 title：props.title > toolMeta.title > 自动拼接 "{name} - DevTools" */
const finalTitle = title || toolMeta?.title || (toolMeta ? `${toolMeta.name} - DevTools` : undefined);

/** 确定最终 description：优先 props → seoDescription → 默认值 */
const finalDescription = description || toolMeta?.seoDescription || undefined;

/** 提取 keywords */
const keywords = toolMeta?.keywords;

/** 获取相关工具 ID 列表 */
const relatedToolIds = toolMeta?.relatedToolIds || [];

/** 获取当前工具的 FAQ 列表 */
const faqs = getToolFaqs(toolId);

/** 站点基础 URL */
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://tools.baixuanz.cn';

/** 构建 JSON-LD 结构化数据 */
const jsonLdItems: object[] = [];

if (toolId && toolMeta) {
  const [categorySlug] = toolId.split('/');
  const categoryName = slugCategoryMap[categorySlug] || categorySlug;
  const toolPageUrl = `${siteUrl}/${toolId}`;

  // 1. BreadcrumbList — 面包屑结构化数据
  jsonLdItems.push({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: '首页',
        item: siteUrl,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: categoryName,
        item: `${siteUrl}/${categorySlug}`,
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: toolMeta.name,
      },
    ],
  });

  // 2. WebPage — 页面信息
  jsonLdItems.push({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: toolMeta.name,
    description: toolMeta.seoDescription,
    url: toolPageUrl,
    breadcrumb: {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '首页', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: categoryName },
        { '@type': 'ListItem', position: 3, name: toolMeta.name },
      ],
    },
  });

  // 3. SoftwareApplication — 工具信息
  jsonLdItems.push({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: toolMeta.name,
    description: toolMeta.seoDescription,
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Browser',
    offers: {
      '@type': 'Offer',
      price: '0',
    },
  });

  // 4. FAQPage — 常见问题结构化数据（仅当工具配置了 FAQ 时输出）。
  // answer 含白名单 HTML（<code>/<strong> 等）直接原样提交，由搜索引擎解析。
  // 注：Google 已于 2026/05 废除 FAQ 富结果，此 schema 仍服务于 AI 检索（GEO）及其他搜索引擎。
  if (faqs.length > 0) {
    jsonLdItems.push({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    });
  }
}

/** 构建面包屑导航项 */
const breadcrumbItems = toolId && toolMeta
  ? (() => {
      const [categorySlug] = toolId.split('/');
      const categoryName = slugCategoryMap[categorySlug] || categorySlug;
      return [
        { label: '首页', href: '/' },
        { label: categoryName },
        { label: toolMeta.name },
      ];
    })()
  : [];

/** 合并工具页自身结构化数据与外部透传（如首页 ItemList） */
const allJsonLd: object[] = [
  ...jsonLdItems,
  ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []),
];
---

<Layout title={finalTitle} description={finalDescription} jsonLd={allJsonLd} keywords={keywords}>
  <div id="app" class="h-dvh flex flex-col overflow-hidden">
    <!-- Header（通栏，横跨全宽） -->
    <header class="flex items-center justify-between px-6 py-2 border-b border-border bg-card h-[57px] shrink-0">
      <!-- 左侧：汉堡按钮（mobile-only） + Logo（全断点常驻） -->
      <div class="flex items-center gap-4">
        <button
          class="hidden max-lg:flex flex-col gap-1 p-2 border-none bg-transparent cursor-pointer focus:outline-none"
          aria-label="打开导航菜单"
          x-data="{ expanded: false }"
          :aria-expanded="expanded"
          @click="$dispatch('sidebar-toggle'); expanded = !expanded"
          @sidebar-toggle.window="expanded = !$el.getAttribute('aria-expanded')"
          @sidebar-close.window="expanded = false"
        >
          <span class="block w-[18px] h-[2px] bg-text rounded-[1px]" aria-hidden="true"></span>
          <span class="block w-[18px] h-[2px] bg-text rounded-[1px]" aria-hidden="true"></span>
          <span class="block w-[18px] h-[2px] bg-text rounded-[1px]" aria-hidden="true"></span>
        </button>
        <a
          href="/"
          class="group flex items-center gap-1.5 text-lg font-semibold text-text hover:text-accent transition-[color] duration-150"
          aria-label="DevTools 首页"
        >
          <Wrench class="w-6 h-6 text-violet-600 group-hover:text-accent group-hover:-rotate-12 transition-[transform,color] duration-300 ease-out" />
          <span>DevTools</span>
        </a>
      </div>

      <!-- 右侧：工具按钮区 -->
      <div class="flex items-center gap-1">

        <!-- 收藏夹入口（桌面显示文字，移动端仅图标） -->
        <a
          href="/favorites"
          class="flex items-center gap-1.5 h-9 px-2 max-md:px-1.5 rounded-sm text-muted hover:text-accent hover:bg-hover transition-[color,background-color] duration-150 focus:outline-none"
          aria-label="我的收藏"
        >
          <Star class="w-5 h-5" />
          <span class="text-[0.8125rem] font-medium max-md:hidden">我的收藏</span>
        </a>

        <!-- 暗色模式按钮（仅 UI 预留） -->
        <button
          class="flex items-center justify-center w-9 h-9 rounded-sm text-muted hover:text-accent hover:bg-hover transition-[color,background-color] duration-150 cursor-pointer border-none bg-transparent focus:outline-none"
          aria-label="切换暗色模式（即将支持）"
          @click="$store.toast.success('暗色模式即将支持，敬请期待')"
        >
          <Sun class="w-5 h-5" />
        </button>

        <!-- Gitee 链接 -->
        <a
          href="https://gitee.com/baixuanz"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-9 h-9 rounded-sm text-muted hover:text-accent hover:bg-hover transition-[color,background-color] duration-150 focus:outline-none"
          aria-label="Gitee 仓库"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" role="img" aria-hidden="true" fill={`#${siGitee.hex}`}>
            <path d={siGitee.path} />
          </svg>
        </a>

        <!-- GitHub 链接 -->
        <a
          href="https://github.com/BaixuanZhu/DevTools"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-9 h-9 rounded-sm text-muted hover:text-accent hover:bg-hover transition-[color,background-color] duration-150 focus:outline-none"
          aria-label="GitHub 仓库"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" role="img" aria-hidden="true" fill="currentColor">
            <path d={siGithub.path} />
          </svg>
        </a>
      </div>
    </header>

    <!-- 主体行：aside + 内容列 -->
    <div class="flex-1 flex min-h-0">
      <!-- Sidebar（桌面纯静态；移动端抽屉，定位见 <style>） -->
      <aside
        x-data="{ isOpen: false }"
        @sidebar-toggle.window="isOpen = !isOpen"
        @sidebar-close.window="isOpen = false"
        @keydown.escape.window="isOpen = false"
        :class="isOpen && 'sidebar-open'"
        class="sidebar w-60 shrink-0 border-r border-border bg-card flex flex-col"
        role="navigation"
        aria-label="工具导航"
      >
        <!-- 导航内容（可滚动） -->
        <div class="flex-1 sidebar-nav-scroll overflow-y-auto py-2">
          {categories.map((category) => (
            <div>
              <h3 class="text-xs font-semibold text-muted px-4 py-4 pb-1 uppercase tracking-wider">{category}</h3>
              <ul class="list-none m-0 p-0">
                {toolsByCategory[category].map((tool) => (
                  <li>
                    <a
                      href={tool.path}
                      class:list={[
                        'flex items-center gap-2 px-4 py-2 text-sm text-text transition-[background-color] duration-150 hover:bg-hover focus:outline-none',
                        currentPath === tool.path && 'bg-hover text-accent font-medium',
                      ]}
                    >
                      <span class="text-base w-6 text-center shrink-0">{tool.icon}</span>
                      <span>{tool.name}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </aside>

      <!-- Mobile overlay -->
      <div
        x-data="{ show: false }"
        @sidebar-toggle.window="show = !show"
        @sidebar-close.window="show = false"
        @keydown.escape.window="show = false"
        x-show="show"
        @click="$dispatch('sidebar-close')"
        class="sidebar-overlay fixed inset-0 bg-black/30 z-[99]"
        x-cloak
      ></div>

      <!-- 内容列（唯一内容滚动容器） -->
      <div class="flex-1 flex flex-col overflow-x-hidden overflow-y-auto min-w-0">
        <!-- Main content -->
        <main class="flex-1 p-8 max-w-full max-md:p-4">
        {breadcrumbItems.length > 0 && <Breadcrumb items={breadcrumbItems} />}
        <slot />
        {faqs.length > 0 && (
          <section class="mt-12 pt-8 border-t border-border">
            <h2 class="text-lg font-semibold text-text mb-4">常见问题</h2>
            <div class="space-y-0 divide-y divide-border">
              {faqs.map((faq) => (
                <details class="group py-4" open>
                  <summary class="flex items-center justify-between cursor-pointer text-[0.8125rem] text-text hover:text-accent transition-[color] duration-150 list-none">
                    <span class="[&_code]:bg-hover [&_code]:text-text [&_code]:font-mono [&_code]:text-xs [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded-sm [&_strong]:text-text [&_strong]:font-semibold" set:html={faq.question} />
                    <ChevronDown class="h-4 w-4 shrink-0 text-muted transition-transform duration-150 group-open:rotate-180" />
                  </summary>
                  <div class="pt-2 text-[0.8125rem] text-muted leading-relaxed [&_code]:bg-hover [&_code]:text-text [&_code]:font-mono [&_code]:text-xs [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded-sm [&_strong]:text-text [&_strong]:font-semibold" set:html={faq.answer} />
                </details>
              ))}
            </div>
          </section>
        )}
        {relatedToolIds.length > 0 && (
          <section class="mt-12 pt-8 border-t border-border">
            <h2 class="text-lg font-semibold text-text mb-4">相关工具</h2>
            <RelatedTools toolIds={relatedToolIds} />
          </section>
        )}
        </main>

        <!-- Footer -->
        <Footer />
      </div>
    </div>

    <!-- Alpine Toast -->
    <Toast />
  </div>

  <style>
    /* 移动端侧边栏行为：从 header 下方滑出，保持 header 常驻可见 */
    @media (max-width: 1023px) {
      .sidebar {
        position: fixed;
        left: 0;
        top: 57px;
        z-index: 100;
        height: calc(100dvh - 57px);
        transform: translateX(-100%);
        transition: transform 250ms ease;
      }
      .sidebar.sidebar-open {
        transform: translateX(0);
      }
      .sidebar-overlay {
        top: 57px;
      }
    }
    /* 桌面端不显示 overlay（aside 为静态常驻，无抽屉） */
    @media (min-width: 1024px) {
      .sidebar-overlay {
        display: none;
      }
    }
  </style>
</Layout>
