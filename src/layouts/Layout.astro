---
import '../styles/global.css';
import SeoHead from '../components/seo/SeoHead.astro';

interface Props {
  title?: string;
  description?: string;
  jsonLd?: object | object[];
}

const { title = 'DevTools - 开发者工具集', description, jsonLd } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://tools.openbong.cloud';

/** 首页 WebSite 结构化数据 */
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'DevTools',
  url: siteUrl,
  description: '零门槛的浏览器端开发者工具集合，即开即用，纯浏览器端运算',
  inLanguage: 'zh-CN',
};

/** 合并 WebSite JSON-LD 与页面自定义 JSON-LD */
const allJsonLd: object[] = [websiteJsonLd];
if (jsonLd) {
  allJsonLd.push(...(Array.isArray(jsonLd) ? jsonLd : [jsonLd]));
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <SeoHead title={title} description={description} jsonLd={allJsonLd} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-surface text-text font-sans text-base leading-normal antialiased">
    <slot />
  </body>
</html>

<script>
  import Alpine from 'alpinejs';

  window.Alpine = Alpine;

  // 注册 Alpine store: toast（通过 DOM CustomEvent 触发）
  Alpine.store('toast', {
    items: [] as { id: number; type: string; message: string }[],
    add(type: string, message: string, duration = 3000) {
      const id = Date.now() + Math.random();
      this.items.push({ id, type, message });
      setTimeout(() => {
        this.items = this.items.filter((t: { id: number }) => t.id !== id);
      }, duration);
    },
    success(message: string) {
      this.add('success', message);
    },
    error(message: string) {
      this.add('error', message);
    },
  });

  /** 收藏夹元数据 */
  interface FavoriteItem {
    path: string;
    name: string;
    icon: string;
  }

  // 注册 Alpine store: favorites（Header 下拉面板 + 侧边栏星标共享）
  Alpine.store('favorites', {
    list: [] as FavoriteItem[],
    maxCount: 10,
    storageKey: 'devtools-favorites',

    /** 从 localStorage 加载收藏数据 */
    load() {
      try {
        const raw = localStorage.getItem(this.storageKey);
        this.list = raw ? JSON.parse(raw) : [];
      } catch {
        this.list = [];
      }
    },

    /** 持久化到 localStorage */
    save() {
      localStorage.setItem(this.storageKey, JSON.stringify(this.list));
    },

    /** 判断指定路径的工具是否已收藏 */
    isFavorite(path: string): boolean {
      return this.list.some((f) => f.path === path);
    },

    /** 切换收藏状态 */
    toggle(path: string, name: string, icon: string) {
      if (this.isFavorite(path)) {
        this.list = this.list.filter((f) => f.path !== path);
        Alpine.store('toast').success(`已取消收藏 ${name}`);
      } else {
        if (this.list.length >= this.maxCount) {
          Alpine.store('toast').error(`最多收藏 ${this.maxCount} 个工具`);
          return;
        }
        this.list = [...this.list, { path, name, icon }];
        Alpine.store('toast').success(`已收藏 ${name}`);
      }
      this.save();
    },

    /** 清空全部收藏 */
    clearAll() {
      this.list = [];
      this.save();
      Alpine.store('toast').success('已清空全部收藏');
    },
  });

  // 页面加载时先初始化收藏数据（在 Alpine 启动前，避免首帧闪动）
  Alpine.store('favorites').load();

  Alpine.start();

  // 桥接 DOM CustomEvent → Alpine toast store
  document.addEventListener('toast', ((e: CustomEvent) => {
    const { type = 'success', message } = e.detail || {};
    if (message) Alpine.store('toast').add(type, message);
  }) as EventListener);
</script>
