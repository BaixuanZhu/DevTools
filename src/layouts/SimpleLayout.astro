---
/**
 * SimpleLayout — 非工具页面的轻量级布局
 *
 * 提供 Header（Logo + 首页链接）+ 居中内容区 + Footer，
 * 不包含工具侧边栏。适用于反馈、关于等独立页面。
 */
import Layout from './Layout.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  /** 页面标题 */
  title?: string;
  /** 页面描述 */
  description?: string;
}

const { title, description } = Astro.props;
---

<Layout title={title} description={description}>
  <div class="min-h-dvh flex flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-50 flex items-center justify-between px-6 py-2 border-b border-border bg-card h-[57px] shrink-0">
      <!-- Logo -->
      <a
        href="/"
        class="group flex items-center gap-1.5 text-lg font-semibold text-text hover:text-accent transition-[color] duration-150"
        aria-label="DevTools 首页"
      >
        <svg
          class="w-6 h-6 text-text group-hover:text-accent group-hover:-rotate-12 transition-[transform,color] duration-300 ease-out"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="16 18 22 12 16 6"></polyline>
          <polyline points="8 6 2 12 8 18"></polyline>
        </svg>
        <span>DevTools</span>
      </a>

      <!-- 右侧链接区 -->
      <div class="flex items-center gap-4">
        <a
          href="/about"
          class="text-[0.8125rem] text-muted hover:text-accent transition-[color] duration-150"
        >关于</a>
        <a
          href="/feedback"
          class="text-[0.8125rem] text-muted hover:text-accent transition-[color] duration-150"
        >反馈</a>
        <a
          href="https://gitee.com/baixuanz"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[0.8125rem] text-muted hover:text-accent transition-[color] duration-150"
        >Gitee</a>
        <a
          href="https://github.com/BaixuanZhu/DevTools"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[0.8125rem] text-muted hover:text-accent transition-[color] duration-150"
        >GitHub</a>
      </div>
    </header>

    <!-- Main content -->
    <main class="flex-1 p-8 max-w-3xl mx-auto w-full max-md:p-4">
      <slot />
    </main>

    <!-- Footer -->
    <Footer />
  </div>

  <!-- Alpine Toast -->
  <div
    class="fixed top-20 left-1/2 -translate-x-1/2 z-[100] flex flex-col-reverse gap-3 max-w-[90vw]"
    x-cloak
    x-data
    role="region"
    aria-label="通知"
    set:html={`<template x-for="toast in $store.toast.items" :key="toast.id">
      <div
        :class="{
          'border-border': toast.type === 'success',
          'border-error/20': toast.type === 'error',
        }"
        class="flex items-center gap-3 px-5 py-3.5 rounded-lg border shadow-lg bg-card text-text text-sm font-sans min-w-48 max-w-sm"
        role="status"
        aria-live="polite"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 -translate-y-2 scale-95"
        x-transition:enter-end="opacity-100 translate-y-0 scale-100"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100 translate-y-0 scale-100"
        x-transition:leave-end="opacity-0 -translate-y-2 scale-95"
      >
        <svg
          x-show="toast.type === 'success'"
          class="w-5 h-5 shrink-0 text-success"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
        </svg>
        <svg
          x-show="toast.type === 'error'"
          class="w-5 h-5 shrink-0 text-error"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
        </svg>
        <span x-text="toast.message"></span>
      </div>
    </template>`}
  ></div>
</Layout>
