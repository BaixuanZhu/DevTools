---
/**
 * 反馈建议页面
 *
 * 提供反馈表单，用户填写后通过 mailto: 链接
 * 打开邮件客户端发送到 wy2359117018@163.com。
 */
import SimpleLayout from '../layouts/SimpleLayout.astro';
---

<SimpleLayout title="反馈建议 | DevTools" description="向 DevTools 提交反馈建议、Bug 报告或功能需求">
  <div
    x-data="{
      type: '功能建议',
      content: '',
      contact: '',
      submitting: false,
      submit() {
        if (!this.content.trim()) {
          $store.toast.error('请填写反馈内容');
          return;
        }
        var subject = encodeURIComponent('[DevTools 反馈] ' + this.type);
        var body = encodeURIComponent(
          '反馈类型：' + this.type + '\\n\\n' +
          '反馈内容：\\n' + this.content +
          (this.contact.trim() ? '\\n\\n联系方式：' + this.contact.trim() : '')
        );
        window.location.href = 'mailto:wy2359117018@163.com?subject=' + subject + '&body=' + body;
        $store.toast.success('已打开邮件客户端，感谢你的反馈！');
      }
    }"
  >
    <!-- 页面标题 -->
    <h1 class="text-3xl font-bold text-text m-0 mb-2">反馈建议</h1>
    <p class="text-muted text-base m-0 mb-8">你的反馈对改进工具至关重要，我们会认真对待每一条建议</p>

    <!-- 反馈表单 -->
    <form class="space-y-5" @submit.prevent="submit()">
      <!-- 反馈类型 -->
      <div>
        <label for="feedback-type" class="block text-sm font-medium text-text mb-1.5">反馈类型</label>
        <select
          id="feedback-type"
          x-model="type"
          class="w-full px-3 py-2.5 border border-border rounded-sm bg-card text-text text-base font-sans transition-[border-color] duration-150 focus:border-accent focus:outline-none appearance-none cursor-pointer"
        >
          <option>功能建议</option>
          <option>Bug 报告</option>
          <option>体验问题</option>
          <option>其他</option>
        </select>
      </div>

      <!-- 详细描述 -->
      <div>
        <label for="feedback-content" class="block text-sm font-medium text-text mb-1.5">
          详细描述
          <span class="text-error text-xs ml-1">*</span>
        </label>
        <textarea
          id="feedback-content"
          x-model="content"
          placeholder="请描述你的建议或遇到的问题..."
          rows="6"
          class="w-full px-3 py-2.5 border border-border rounded-sm bg-card text-text text-base font-sans transition-[border-color] duration-150 focus:border-accent focus:outline-none resize-y min-h-40 placeholder:text-muted"
          required
        ></textarea>
      </div>

      <!-- 联系方式 -->
      <div>
        <label for="feedback-contact" class="block text-sm font-medium text-text mb-1.5">
          联系方式
          <span class="text-muted text-xs font-normal ml-1">（可选，方便我们跟进）</span>
        </label>
        <input
          id="feedback-contact"
          type="text"
          x-model="contact"
          placeholder="邮箱或微信号"
          class="w-full px-3 py-2.5 border border-border rounded-sm bg-card text-text text-base font-sans transition-[border-color] duration-150 focus:border-accent focus:outline-none placeholder:text-muted"
        />
      </div>

      <!-- 提交按钮 -->
      <div class="pt-2">
        <button
          type="submit"
          class="px-6 py-2.5 bg-accent text-white rounded-sm font-medium text-base cursor-pointer border-none hover:opacity-90 transition-opacity"
        >
          发送反馈
        </button>
      </div>
    </form>
  </div>
</SimpleLayout>
