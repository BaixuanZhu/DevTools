---
/**
 * 关于 DevTools 页面
 *
 * 展示项目介绍、核心特性、技术栈、开源链接和联系方式。
 */
import SimpleLayout from '../layouts/SimpleLayout.astro';
import { siGithub, siGitee } from 'simple-icons';
---

<SimpleLayout title="关于 DevTools | DevTools" description="了解 DevTools 在线工具箱的项目信息、核心特性和技术栈">
  <!-- 页面标题 -->
  <h1 class="text-3xl font-bold text-text m-0 mb-3">关于 DevTools</h1>
  <p class="text-muted text-base m-0 leading-relaxed">
    DevTools 是一款面向开发者的在线工具集合。所有工具均在浏览器本地运行，无需安装、无需注册，打开即用。
    我们致力于为开发者提供零门槛的日常开发辅助工具，让繁杂的编码、转换、格式化工作变得简单高效。
  </p>

  <!-- 核心特性 -->
  <section class="mt-10">
    <h2 class="text-xl font-semibold text-text m-0 mb-4">核心特性</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <!-- 隐私优先 -->
      <div class="p-5 bg-card border border-border rounded-lg">
        <div class="text-2xl mb-2">🔒</div>
        <h3 class="text-base font-semibold text-text m-0 mb-1">隐私优先</h3>
        <p class="text-sm text-muted m-0">所有运算在浏览器本地完成，你的数据不会上传到任何服务器</p>
      </div>
      <!-- 即开即用 -->
      <div class="p-5 bg-card border border-border rounded-lg">
        <div class="text-2xl mb-2">⚡</div>
        <h3 class="text-base font-semibold text-text m-0 mb-1">即开即用</h3>
        <p class="text-sm text-muted m-0">无需安装软件、无需注册账号，打开浏览器即可使用全部工具</p>
      </div>
      <!-- 响应式设计 -->
      <div class="p-5 bg-card border border-border rounded-lg">
        <div class="text-2xl mb-2">📱</div>
        <h3 class="text-base font-semibold text-text m-0 mb-1">响应式设计</h3>
        <p class="text-sm text-muted m-0">适配桌面和移动端，随时随地使用你需要的开发工具</p>
      </div>
      <!-- 完全免费 -->
      <div class="p-5 bg-card border border-border rounded-lg">
        <div class="text-2xl mb-2">🆓</div>
        <h3 class="text-base font-semibold text-text m-0 mb-1">完全免费</h3>
        <p class="text-sm text-muted m-0">开源项目，所有功能永久免费使用，欢迎参与贡献</p>
      </div>
    </div>
  </section>

  <!-- 技术栈 -->
  <section class="mt-10">
    <h2 class="text-xl font-semibold text-text m-0 mb-4">技术栈</h2>
    <div class="flex flex-wrap gap-2">
      <span class="inline-block px-3 py-1.5 bg-card border border-border rounded-sm text-sm text-text font-medium">Astro 6</span>
      <span class="inline-block px-3 py-1.5 bg-card border border-border rounded-sm text-sm text-text font-medium">Vue 3</span>
      <span class="inline-block px-3 py-1.5 bg-card border border-border rounded-sm text-sm text-text font-medium">TypeScript</span>
      <span class="inline-block px-3 py-1.5 bg-card border border-border rounded-sm text-sm text-text font-medium">Tailwind CSS</span>
      <span class="inline-block px-3 py-1.5 bg-card border border-border rounded-sm text-sm text-text font-medium">Alpine.js</span>
      <span class="inline-block px-3 py-1.5 bg-card border border-border rounded-sm text-sm text-text font-medium">Web Workers</span>
    </div>
  </section>

  <!-- 开源链接 -->
  <section class="mt-10">
    <h2 class="text-xl font-semibold text-text m-0 mb-4">开源仓库</h2>
    <div class="flex flex-wrap gap-4">
      <a
        href="https://gitee.com/baixuanz"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 px-4 py-2.5 bg-card border border-border rounded-sm text-sm text-text hover:border-accent transition-[border-color] duration-150"
      >
        <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" role="img" aria-hidden="true" fill={`#${siGitee.hex}`}>
          <path d={siGitee.path} />
        </svg>
        Gitee
      </a>
      <a
        href="https://github.com/BaixuanZhu/DevTools"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 px-4 py-2.5 bg-card border border-border rounded-sm text-sm text-text hover:border-accent transition-[border-color] duration-150"
      >
        <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" role="img" aria-hidden="true" fill="currentColor">
          <path d={siGithub.path} />
        </svg>
        GitHub
      </a>
    </div>
  </section>

  <!-- 联系方式 -->
  <section class="mt-10">
    <h2 class="text-xl font-semibold text-text m-0 mb-4">联系方式</h2>
    <p class="text-muted text-base m-0">
      如果你有任何问题或建议，欢迎通过以下方式联系我们：
    </p>
    <div class="mt-3">
      <a
        href="mailto:wy2359117018@163.com"
        class="text-accent hover:opacity-80 transition-opacity text-base"
      >wy2359117018@163.com</a>
    </div>
  </section>
</SimpleLayout>
