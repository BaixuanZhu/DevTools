---
/**
 * 旧扁平 URL 重定向页面
 * 旧路径：/base64, /hash-generator 等
 * 新路径：/encoding/base64, /crypto/hash-generator 等
 */
export function getStaticPaths() {
  const redirects: Record<string, string> = {
    'base64': '/encoding/base64',
    'url-encode': '/encoding/url-encode',
    'jwt-parser': '/encoding/jwt-parser',
    'hash-generator': '/crypto/hash-generator',
    'symmetric-crypto': '/crypto/symmetric-crypto',
    'uuid-generator': '/text/uuid-generator',
    'random-string': '/text/random-string',
    'datetime-converter': '/datetime/datetime-converter',
    'device-info': '/network/device-info',
  };

  return Object.keys(redirects).map((slug) => ({
    params: { slug },
    props: { destination: redirects[slug] },
  }));
}

const { destination } = Astro.props;
---

<html>
  <head>
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <link rel="canonical" href={destination} />
    <title>Redirecting...</title>
  </head>
  <body>
    <p>此页面已迁移至 <a href={destination}>{destination}</a></p>
  </body>
</html>
