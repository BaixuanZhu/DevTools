---
import ToolLayout from '../layouts/ToolLayout.astro';
import ToolCard from '../components/layout/ToolCard.astro';
import { tools } from '../data/tools';

// 序列化工具数据供客户端搜索使用
const toolsJson = JSON.stringify(
  tools.map((t) => ({
    id: t.id,
    name: t.name,
    description: t.description,
  })),
);
---

<ToolLayout title="DevTools - 开发者工具集">
  <div
    class="max-w-[1280px] mx-auto"
    x-data="{ query: '', searchIds: null, tools: [], init() { var el = document.getElementById('tools-data'); this.tools = el ? JSON.parse(el.textContent || '[]') : []; }, applyFilter() { var self = this; this.$refs.grid.querySelectorAll('[data-category]').forEach(function(el) { var id = el.getAttribute('data-id'); var matchSearch = !self.searchIds || self.searchIds.has(id); el.style.display = matchSearch ? '' : 'none'; }); }, handleSearch() { if (!this.query.trim()) { this.searchIds = null; this.applyFilter(); return; } var q = this.query.toLowerCase(); var results = this.tools.filter(function(t) { return t.name.toLowerCase().includes(q) || t.description.toLowerCase().includes(q); }); this.searchIds = new Set(results.map(function(t) { return t.id; })); this.applyFilter(); } }"
  >
    <!-- Hero Section -->
    <div class="text-center mb-10">
      <h1 class="text-4xl font-bold m-0 mb-3">开发者工具集</h1>
      <p class="text-muted text-base m-0 mb-8">零门槛的浏览器端开发者工具，即开即用</p>

      <!-- Search Bar -->
      <div class="max-w-[560px] mx-auto mb-6">
        <div class="flex items-center gap-2 px-5 py-3 border border-border rounded-lg bg-card transition-[border-color] duration-150 focus-within:border-accent">
          <span class="text-base shrink-0">🔍</span>
          <input
            type="text"
            x-model="query"
            placeholder="搜索工具..."
            class="flex-1 border-none outline-none text-base font-sans text-text bg-transparent placeholder:text-muted"
            @input.debounce.150ms="handleSearch()"
          />
          <button
            x-show="query"
            x-cloak
            @click="query = ''; handleSearch()"
            class="border-none bg-transparent cursor-pointer text-muted text-sm px-1 py-0.5 rounded-sm hover:text-text"
            aria-label="清除搜索"
          >✕</button>
        </div>
      </div>

      <!-- 收藏工具 -->
      <div
        x-show="$store.favorites.list.length > 0"
        x-cloak
        class="mb-8"
        x-transition
      >
        <h2 class="text-sm font-semibold text-muted mb-3">⭐ 我的收藏</h2>
        <div class="grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))] gap-3">
          <template x-for="fav in $store.favorites.list" :key="fav.path">
            <a
              :href="fav.path"
              class="flex items-center gap-3 p-3 bg-card border border-border rounded-lg transition-[border-color,box-shadow] duration-150 hover:border-accent hover:shadow-[0_2px_8px_rgba(0,0,0,0.06)]"
            >
              <span class="text-2xl leading-none" x-text="fav.icon"></span>
              <span class="text-[0.9375rem] font-semibold text-text" x-text="fav.name"></span>
            </a>
          </template>
        </div>
      </div>
    </div>

    <!-- Tool Cards Grid -->
    <div
      class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-4"
      x-ref="grid"
    >
      {tools.map((tool) => (
        <div data-category={tool.category} data-id={tool.id} class="flex">
          <ToolCard tool={tool} />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div
      x-show="query && searchIds && searchIds.size === 0"
      x-cloak
      class="text-center py-16"
    >
      <p class="text-muted text-base m-0">没有找到匹配「<span x-text="query" class="text-text font-medium"></span>」的工具</p>
    </div>
  </div>

  <!-- Hidden tools data for client-side search -->
  <script is:inline id="tools-data" type="application/json" set:html={toolsJson} />
</ToolLayout>
