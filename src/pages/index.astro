---
import ToolLayout from '../layouts/ToolLayout.astro';
import ToolCard from '../components/layout/ToolCard.astro';
import { tools, getCategories } from '../data/tools';

const categories = getCategories();
---

<ToolLayout title="DevTools - 开发者工具集">
  <div class="max-w-[960px] mx-auto">
    <h1 class="text-2xl font-semibold m-0 mb-6">开发者工具集</h1>

    <div class="flex gap-2 overflow-x-auto pb-2 mb-6 [-webkit-overflow-scrolling:touch]"
      x-data="{ active: 'all' }"
    >
      <button
        class="px-4 py-1 border border-border rounded-lg bg-card text-muted text-[0.8125rem] font-sans whitespace-nowrap cursor-pointer transition-[background-color,color,border-color] duration-150 hover:bg-hover hover:text-text"
        :class="active === 'all' && 'bg-accent text-white border-accent'"
        @click="active = 'all'; applyFilter()"
      >
        全部
      </button>
      {categories.map((cat) => (
        <button
          class="px-4 py-1 border border-border rounded-lg bg-card text-muted text-[0.8125rem] font-sans whitespace-nowrap cursor-pointer transition-[background-color,color,border-color] duration-150 hover:bg-hover hover:text-text"
          :class={`active === '${cat}' && 'bg-accent text-white border-accent'`}
          @click={`active = '${cat}'; applyFilter()`}
        >
          {cat}
        </button>
      ))}
    </div>

    <div
      class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-4"
      x-data="{
        active: 'all',
        searchIds: null as Set<string> | null,
        init() {
          document.addEventListener('search-results', ((e: CustomEvent) => {
            this.searchIds = e.detail.query ? new Set(e.detail.tools.map((t: any) => t.id)) : null;
            this.applyFilter();
          }) as EventListener);
        },
        applyFilter() {
          this.$refs.grid.querySelectorAll('[data-category]').forEach((el: HTMLElement) => {
            const cat = el.getAttribute('data-category')!;
            const id = el.querySelector('a')?.getAttribute('href')?.slice(1);
            const matchCategory = this.active === 'all' || cat === this.active;
            const matchSearch = !this.searchIds || (id && this.searchIds.has(id));
            el.style.display = matchCategory && matchSearch ? '' : 'none';
          });
        }
      }"
      x-ref="grid"
    >
      {tools.map((tool) => (
        <div data-category={tool.category}>
          <ToolCard tool={tool} />
        </div>
      ))}
    </div>
  </div>
</ToolLayout>
