---
/**
 * 404 页面 - 页面未找到
 * 当用户访问不存在的路径时显示
 */
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - 页面未找到 | DevTools">
  <div class="flex min-h-screen items-center justify-center px-6">
    <div class="text-center">
      <div class="text-8xl font-bold text-muted mb-4">404</div>
      <h1 class="text-2xl font-semibold text-text mb-2">页面未找到</h1>
      <p class="text-muted mb-8">你访问的页面不存在或已被移动</p>
      <a
        href="/"
        class="inline-block px-6 py-3 bg-accent text-white rounded-sm font-medium hover:opacity-90 transition-opacity"
      >
        返回首页
      </a>
    </div>
  </div>
</Layout>
